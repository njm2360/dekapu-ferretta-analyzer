<Window x:Class="DekapuFeletta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DekapuFeletta.ViewModels"
        Title="フェレッタ ショット選択支援ツール"
        Width="1510" Height="630"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo"
        FontSize="13"
        Background="#1E1F22">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="CellButton" TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#404452"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7AA2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#2D5A2D"/>
                    <Setter Property="BorderBrush" Value="#5FCB5F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="False">
                    <Setter Property="Background" Value="#2A2D34"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsActive}" Value="False"/>
                        <Condition Binding="{Binding IsReach}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3A2D1A"/>
                    <Setter Property="BorderBrush" Value="#FF9F70"/>
                    <Setter Property="Foreground" Value="#FFD8B8"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsActive}" Value="False"/>
                        <Condition Binding="{Binding IsMultiTrigger}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3D1F3F"/>
                    <Setter Property="BorderBrush" Value="#E879F9"/>
                    <Setter Property="Foreground" Value="#F5C6FF"/>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsCenter}" Value="True">
                    <Setter Property="Background" Value="#7A5C00"/>
                    <Setter Property="BorderBrush" Value="#E6B800"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultRow" TargetType="Border">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#262830"/>
        </Style>

        <Style x:Key="DistChip" TargetType="Border">
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="#1A1B1F"/>
            <Setter Property="MinWidth" Value="46"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasMass}" Value="True">
                    <Setter Property="Background" Value="#2A3A52"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AA0A6"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <Style x:Key="MetricValueExpected" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8B8B8"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBestExpected}" Value="True">
                    <Setter Property="Foreground" Value="#FFD86A"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricValueDeltaActive" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBestDeltaActive}" Value="True">
                    <Setter Property="Foreground" Value="#5FCB5F"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricValueDeltaReach" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBestDeltaReach}" Value="True">
                    <Setter Property="Foreground" Value="#7AA2F7"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricValueTrigger" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBestTriggerCells}" Value="True">
                    <Setter Property="Foreground" Value="#E879F9"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricValueConditional" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBestConditional}" Value="True">
                    <Setter Property="Foreground" Value="#FF9F70"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricValueReset" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Board input -->
        <StackPanel Grid.Column="0" Width="340">
            <TextBlock Text="盤面入力" FontSize="18" FontWeight="Bold"
                       Foreground="#E6E6E6" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="5" Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource CellButton}"
                                Command="{Binding ToggleCommand}"
                                Height="62" Width="62"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Number}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="★" FontSize="12" HorizontalAlignment="Center"
                                               Foreground="#FFD86A">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCenter}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,3,3,0"
                                        Background="#E879F9" CornerRadius="7"
                                        MinWidth="14" Height="14"
                                        Padding="3,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMultiTrigger}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ReachBadge}"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#1E1F22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="全クリア" Command="{Binding ClearAllCommand}"
                        Padding="14,6" Margin="0,0,8,0" Background="#3A3D45" Foreground="#E6E6E6" BorderThickness="0"/>
                <Button Content="全埋め" Command="{Binding FillAllCommand}"
                        Padding="14,6" Background="#3A3D45" Foreground="#E6E6E6" BorderThickness="0"/>
            </StackPanel>

            <TextBlock Text="{Binding ActiveCountText}" Foreground="#9AA0A6" Margin="0,12,0,0"/>

            <Button Command="{Binding CalculateCommand}"
                    Padding="14,10" Margin="0,14,0,0"
                    Background="#3D6BB5" Foreground="#FFFFFF" BorderThickness="0"
                    FontSize="15" FontWeight="Bold"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="計算実行"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCalculating}" Value="True">
                                <Setter Property="Content" Value="計算中..."/>
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Background" Value="#555E6E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDirty}" Value="False">
                                <Setter Property="Background" Value="#2D5A2D"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <CheckBox Content="盤面変更時に自動計算する"
                      IsChecked="{Binding IsAutoCalculate}"
                      Foreground="#E6E6E6"
                      Margin="0,8,0,0"/>

            <TextBlock Text="{Binding StatusText}" Foreground="#FFC857" Margin="0,8,0,0" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FFC857"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDirty}" Value="False">
                                <Setter Property="Foreground" Value="#5FCB5F"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding LastElapsedText}" Foreground="#7C8089" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Right: Results -->
        <Grid Grid.Column="1" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="計算結果" FontSize="18" FontWeight="Bold"
                       Foreground="#E6E6E6" Margin="0,0,0,8"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ResultRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="#E6E6E6"
                                                   FontWeight="Bold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- E[L] -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="E[L]" Style="{StaticResource MetricLabel}"
                                                   ToolTip="平均ライン成立数 (素の期待値)"/>
                                        <TextBlock Text="{Binding ExpectedDisplay}"
                                                   Style="{StaticResource MetricValueExpected}"/>
                                    </StackPanel>

                                    <!-- E[L | hit] - conditional expected lines given a hit -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="E[L|hit]" Style="{StaticResource MetricLabel}"
                                                   ToolTip="ヒット時の条件付き平均ライン数 = E[L] / P(L≥1)。コンスタント型 vs 爆発型の見分け"/>
                                        <TextBlock Text="{Binding ConditionalExpectedDisplay}"
                                                   Style="{StaticResource MetricValueConditional}"/>
                                    </StackPanel>

                                    <Border Grid.Column="3" Width="1" Background="#3A3D45" Margin="3,4"/>

                                    <!-- ΔActive (accumulation) -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="+Active" Style="{StaticResource MetricLabel}"
                                                   ToolTip="次抽選開始時のアクティブマス変化量。ライン成立で消えた分を差し引いた純増。負なら蓄積消費"/>
                                        <TextBlock Text="{Binding DeltaActiveDisplay}"
                                                   Style="{StaticResource MetricValueDeltaActive}"/>
                                    </StackPanel>

                                    <!-- ΔReach (reach building) -->
                                    <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="+Reach" Style="{StaticResource MetricLabel}"
                                                   ToolTip="次抽選開始時のリーチライン数の変化量 (4/5マス埋まりのライン)。負なら成立で消費"/>
                                        <TextBlock Text="{Binding DeltaReachDisplay}"
                                                   Style="{StaticResource MetricValueDeltaReach}"/>
                                    </StackPanel>

                                    <!-- Trigger cells (multi-line trigger candidates) -->
                                    <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="Trigger" Style="{StaticResource MetricLabel}"
                                                   ToolTip="次抽選開始時に「2本以上のリーチが集中する非アクティブマス」の数。多いほど次回の大ティア狙いが現実的"/>
                                        <TextBlock Text="{Binding TriggerCellsDisplay}"
                                                   Style="{StaticResource MetricValueTrigger}"/>
                                    </StackPanel>

                                    <!-- E[Reset] - cells reset due to line completion -->
                                    <StackPanel Grid.Column="7" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <TextBlock Text="Reset" Style="{StaticResource MetricLabel}"
                                                   ToolTip="ライン成立で非アクティブに戻されるマス数の期待値。蓄積消費の生コスト"/>
                                        <TextBlock Text="{Binding ResetCellsDisplay}"
                                                   Style="{StaticResource MetricValueReset}"/>
                                    </StackPanel>

                                    <Border Grid.Column="8" Width="1" Background="#3A3D45" Margin="3,4"/>

                                    <!-- Distribution chips -->
                                    <ItemsControl Grid.Column="9" ItemsSource="{Binding Distribution}"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DistChip}"
                                                        ToolTip="{Binding ProbabilityExact}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" Foreground="#9AA0A6"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ProbabilityDisplay}"
                                                                   Foreground="#E6E6E6" FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
